      "title": "Usuário",
      "description": "Dados do perfil do usuário mentor ou profissional",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user", "client"] },
        "profissao": { "type": "string" },
        "especialidade": { "type": "string" },
        "telefone": { "type": "string" },
        "habilitado": { "type": "boolean" },
        "cargo": { "type": "string" },
        "setor": { "type": "string" },
        "tipo_usuario": { "type": "string" },
        "photo_url": { "type": "string" },
        "welcome_email_sent": { "type": "boolean" },
        "onboarding_completed": { "type": "boolean" },
        "notification_preferences": {
          "type": "object",
          "properties": {
            "sessions": { "type": "boolean" },
            "goals": { "type": "boolean" },
            "ai_tips": { "type": "boolean" }
          }
        },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name"]
    },
    "AdminAuditLog": {
      "title": "Registro de Auditoria Administrativa",
      "description": "Log técnico de ações realizadas em rotas administrativas.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "action": { "type": "string" },
        "ip": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "RodaDaVida": {
      "title": "Roda da Vida",
      "description": "Avaliação da Roda da Vida",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "created_by": { "type": "string" },
        "cliente_id": { "type": "string", "description": "ID do cliente vinculado" },
        "created_date": { "type": "string", "format": "date-time" },
